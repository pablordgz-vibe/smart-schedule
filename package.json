{
  "name": "smart-schedule",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "coverage:critical": "node ./scripts/ci/coverage-gate.mjs critical",
    "coverage:repo": "node ./scripts/ci/coverage-gate.mjs repo",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "coverage:gate": "pnpm run coverage:repo && pnpm run coverage:critical",
    "typecheck": "node ./scripts/ci/typecheck.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,css,html,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,css,html,json,md,yml,yaml}\"",
    "boundary:check": "node ./scripts/ci/verify-boundaries.mjs",
    "design-system:check": "node ./scripts/ci/verify-design-system.mjs",
    "workflow:self-test": "node ./scripts/ci/verify-workflows.mjs",
    "migration:check": "node ./scripts/ci/migration-check.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@testcontainers/postgresql": "^10.28.0",
    "@vitest/coverage-v8": "^3.0.7",
    "eslint": "^9.21.0",
    "pg": "^8.20.0",
    "playwright": "^1.50.1",
    "prettier": "latest",
    "turbo": "latest",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  },
  "pnpm": {
    "overrides": {
      "undici": ">=6.23.0",
      "@angular-devkit/core>ajv": ">=8.18.0"
    }
  },
  "packageManager": "pnpm@10.32.0"
}
