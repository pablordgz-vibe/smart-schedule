{
  "name": "@smart-schedule/config",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "test": "pnpm exec vitest run",
    "test:cov": "pnpm exec vitest run --coverage --coverage.reporter=json-summary --coverage.reporter=text --coverage.all=false"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "tsup": "latest",
    "typescript": "latest"
  }
}
